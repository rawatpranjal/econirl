\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Type B counterfactual error for $k = 3$ with 3 seeds. AIRL without anchors and AIRL with anchors achieve the lowest error, at 0.106 and 0.105. GLADIUS is close at about 0.13. Tabular IQ-Learn has local optima and degrades at large $N$. Reduced-form plateaus at 0.262 because it targets the wrong object. NFXP remains pending in this table.}}{6}{table.4}\protected@file@percent }
\newlabel{tab:samplesize}{{4}{6}{Type B counterfactual error for $k = 3$ with 3 seeds. AIRL without anchors and AIRL with anchors achieve the lowest error, at 0.106 and 0.105. GLADIUS is close at about 0.13. Tabular IQ-Learn has local optima and degrades at large $N$. Reduced-form plateaus at 0.262 because it targets the wrong object. NFXP remains pending in this table}{table.4}{}}
