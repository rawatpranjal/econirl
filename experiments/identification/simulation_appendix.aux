\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Content-based paywall counterfactual. The reduced-form estimator fails by 18.5 percentage points because it cannot separate content utility from continuation value.}}{7}{table.6}\protected@file@percent }
