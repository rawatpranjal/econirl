\@writefile{toc}{\contentsline {subsection}{\numberline {5.7}G. State-only reward (Fu et al.\ transfer test)}{7}{subsection.5.7}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces State-only reward DGP. AIRL with state-only $g_\theta (s)$ recovers $r^*(s)$ up to a constant, so the MSE remains positive while the correlation is 1. It transfers perfectly and yields zero Type B counterfactual error. This is the mechanism behind the Fu et al.\ sim-to-real experiments. Generic AIRL without the state-only restriction still fails, with error 0.026, because the shaping residual is action-dependent. The reduced-form advantage has zero correlation with $r^*(s)$ because the true reward is identical across actions and the advantage reflects only continuation-value differences.}}{7}{table.7}\protected@file@percent }
\newlabel{tab:stateonly}{{7}{7}{State-only reward DGP. AIRL with state-only $g_\theta (s)$ recovers $r^*(s)$ up to a constant, so the MSE remains positive while the correlation is 1. It transfers perfectly and yields zero Type B counterfactual error. This is the mechanism behind the Fu et al.\ sim-to-real experiments. Generic AIRL without the state-only restriction still fails, with error 0.026, because the shaping residual is action-dependent. The reduced-form advantage has zero correlation with $r^*(s)$ because the true reward is identical across actions and the advantage reflects only continuation-value differences}{table.7}{}}
